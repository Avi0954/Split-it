# Database Configuration
DATABASE_URL=postgresql://user:password@host/dbname

# Allowed CORS Origins (comma separated)
ALLOWED_ORIGINS=https://your-production-frontend.vercel.app,https://your-domain.com

# Security Secret Keys
SECRET_KEY=your_secure_production_secret_key
JWT_SECRET=your_jwt_signing_secret_key

# Email Provider
RESEND_API_KEY=re_your_resend_api_key

# Web Push Notifications (VAPID)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Frontend URL (For emails/links)
FRONTEND_URL=https://your-production-frontend.vercel.app
